# ── API (apps/api) ────────────────────────────────────────
NODE_ENV=development
PORT=3000

# Prisma ulanishi. docker-compose default qiymatlariga mos:
#   user=instagram pass=instagram db=instagram_mvp port=5432
DATABASE_URL="postgresql://instagram:instagram@localhost:5432/instagram_mvp?schema=public"

# CORS — frontend origin
CORS_ORIGIN=http://localhost:5173

# ── Auth (M1) ─────────────────────────────────────────────
# Kuchli tasodifiy qiymatlar bilan to'ldiring (min 16 belgi):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=dev-access-secret-change-me-min16
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-min16
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
COOKIE_SECURE=false

# ── Media (lokal filesystem) ─────────────────────────────
# Fayllar saqlanadigan papka (absolute yoki process.cwd() ga nisbatan)
UPLOAD_DIR=uploads
# Server public URL (avatar URL uchun)
API_BASE_URL=http://localhost:3000

# ── Google OAuth (M1) ────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback
# WEB_AUTH_REDIRECT=http://localhost:5173/auth/callback

# ── docker-compose override (ixtiyoriy) ───────────────────
# POSTGRES_USER=instagram
# POSTGRES_PASSWORD=instagram
# POSTGRES_DB=instagram_mvp
# POSTGRES_PORT=5432
