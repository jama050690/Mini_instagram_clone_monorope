# ── API (apps/api) ────────────────────────────────────────
NODE_ENV=development
PORT=3000

# Prisma ulanishi. docker-compose default qiymatlariga mos:
#   user=instagram pass=instagram db=instagram_mvp port=5432
DATABASE_URL="postgresql://instagram:instagram@localhost:5432/instagram_mvp?schema=public"

# CORS — frontend origin
CORS_ORIGIN=http://localhost:5173

# ── Auth (M1) ─────────────────────────────────────────────
# Kuchli tasodifiy qiymatlar bilan to'ldiring (min 16 belgi):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=dev-access-secret-change-me-min16
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-min16
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
COOKIE_SECURE=false

# ── Media (M2 avatar / M3) ────────────────────────────────
# Yuklangan fayllar papkasi (process.cwd() ga nisbatan). Avatar →
# {UPLOAD_DIR}/avatars/{userId}.{ext}, `/uploads/...` orqali static beriladi.
UPLOAD_DIR=uploads

# ── Keyingi modullarda qo'shiladi ─────────────────────────
# M1 (Google OAuth):
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── docker-compose override (ixtiyoriy) ───────────────────
# Compose default qiymatlar bilan ishlaydi; o'zgartirmoqchi bo'lsangiz:
# POSTGRES_USER=instagram
# POSTGRES_PASSWORD=instagram
# POSTGRES_DB=instagram_mvp
# POSTGRES_PORT=5432
